{% extends 'base.html.twig' %}
{% block card_open %}{% endblock %}
{% block card_close %}{% endblock %}
{% block title %}Mon espace - {{ tenant.name }}{% endblock %}

{% block body %}
<div class="dashboard-header">
    <div>
        <h1>Bonjour, {{ tenant.name }}</h1>
        <p class="dashboard-sub">Espace locataire{{ tenant.property ? ' - ' ~ tenant.property.title : '' }}</p>
    </div>
</div>

<div class="dashboard-grid">

    <div class="card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
            <h3 class="section-title" style="margin:0">Mes quittances de loyer</h3>
            <a href="{{ path('tenant_quittance_index') }}" class="btn-sm">Voir tout &rarr;</a>
        </div>
        {% if receipts is empty %}
            <p style="color:var(--text-muted);padding:16px 0">Aucune quittance pour le moment.</p>
        {% else %}
        <table class="table">
            <thead>
                <tr>
                    <th>Numero</th>
                    <th>Periode</th>
                    <th>Montant</th>
                    <th>Emis le</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            {% for r in receipts|slice(0, 5) %}
                <tr>
                    <td><strong>{{ r.number }}</strong></td>
                    <td>{{ r.periodStart|date('d/m/Y') }} au {{ r.periodEnd|date('d/m/Y') }}</td>
                    <td><strong>{{ r.amount }} EUR</strong></td>
                    <td>{{ r.issuedAt|date('d/m/Y') }}</td>
                    <td><a href="{{ path('tenant_quittance_show', {id: r.id}) }}" class="btn-sm">Voir</a></td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        {% endif %}
    </div>

    <div class="card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
            <h3 class="section-title" style="margin:0">Mon dossier locataire</h3>
            <a href="{{ path('tenant_self_file_index') }}" class="btn-sm">G&eacute;rer &rarr;</a>
        </div>
        {% for key, cat in filesByCategory %}
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border)">
            <div style="display:flex;align-items:center;gap:8px">
                {% if cat.files|length > 0 %}
                    <span style="color:var(--accent);font-size:1rem">ok</span>
                {% elseif cat.required %}
                    <span style="color:#ef4444;font-size:1rem">!</span>
                {% else %}
                    <span style="color:var(--text-muted);font-size:1rem">-</span>
                {% endif %}
                <span style="font-size:.9rem">{{ cat.label }}</span>
                {% if not cat.required %}<span style="font-size:.75rem;color:var(--text-muted)">(optionnel)</span>{% endif %}
            </div>
            <span style="font-size:.8rem;color:{% if cat.files|length > 0 %}var(--accent){% elseif cat.required %}#ef4444{% else %}var(--text-muted){% endif %}">
                {% if cat.files|length > 0 %}{{ cat.files|length }} fichier{{ cat.files|length > 1 ? 's' : '' }}{% elseif cat.required %}Manquant{% else %}Aucun{% endif %}
            </span>
        </div>
        {% endfor %}
    </div>

</div>
{% endblock %}
