{% extends 'base.html.twig' %}
{% block card_open %}{% endblock %}
{% block card_close %}{% endblock %}
{% block title %}{{ file.originalName }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>main.container { max-width: 1400px; }</style>
{% endblock %}

{% block body %}
<div>
<div class="dashboard-header">
    <div>
        <h1>{{ file.originalName }}</h1>
        <p class="dashboard-sub">{{ file.categoryLabel }} — {{ tenant.name }}</p>
    </div>
    <div class="page-actions">
        <a href="{{ backUrl }}" class="btn-sm">← Retour</a>
        <a href="{{ downloadUrl }}" class="btn-sm">⬇ Télécharger</a>
    </div>
</div>

<div class="card">
    {% if isPdf %}
        <iframe
            src="{{ fileUrl }}"
            style="width:100%;height:80vh;border:none;border-radius:8px;"
            title="{{ file.originalName }}"
        ></iframe>
    {% elseif isImage %}
        <div style="text-align:center">
            <img
                src="{{ fileUrl }}"
                alt="{{ file.originalName }}"
                style="max-width:100%;max-height:80vh;border-radius:8px;box-shadow:var(--shadow);"
            >
        </div>
    {% else %}
        <div style="text-align:center;padding:60px 0;color:var(--text-muted)">
            <p style="font-size:3rem;margin-bottom:16px">📄</p>
            <p>Ce type de fichier ne peut pas être prévisualisé.</p>
            <a href="{{ downloadUrl }}" class="btn" style="margin-top:16px">⬇ Télécharger le fichier</a>
        </div>
    {% endif %}
</div>
</div>
{% endblock %}
