{% extends 'base.html.twig' %}
{% block card_open %}{% endblock %}
{% block card_close %}{% endblock %}
{% block title %}Liste des quittances{% endblock %}
{% block body %}
<div class="dashboard-header">
    <div>
        <h1>Quittances de loyer</h1>
        <p class="dashboard-sub">Historique et gestion des quittances</p>
    </div>
    <a href="{{ path('app_rent_receipt_new') }}" class="btn">+ Nouvelle quittance</a>
</div>
<div class="card">
<table class="table">
    <thead>
        <tr>
            <th>Numéro</th>
            <th>Locataire</th>
            <th>Période</th>
            <th>Montant</th>
            <th>Statut</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    {% for r in rent_receipts %}
        <tr>
            <td><span class="badge">{{ r.number }}</span></td>
            <td>{{ r.tenant ? r.tenant.name : '—' }}</td>
            <td style="white-space:nowrap">{{ r.periodStart|date('d/m/Y') }} → {{ r.periodEnd|date('d/m/Y') }}</td>
            <td><strong>{{ r.amount }} €</strong></td>
            <td>
                {% if r.isPaid %}
                    <span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;background:#dcfce7;color:#166534;border-radius:20px;font-size:.8rem;font-weight:600">
                        ✓ Payé
                    </span>
                {% else %}
                    <span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;background:#fef9c3;color:#854d0e;border-radius:20px;font-size:.8rem;font-weight:600">
                        ⏳ En attente
                    </span>
                {% endif %}
            </td>
            <td>
                <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:center">
                    <a href="{{ path('app_rent_receipt_show', {'id': r.id}) }}" class="btn-sm">Voir</a>
                    <a href="{{ path('app_rent_receipt_edit', {'id': r.id}) }}" class="btn-sm">Modifier</a>
                    {% if not r.isPaid %}
                        <a href="{{ path('app_payment_new', {'quittance': r.id}) }}" class="btn-sm btn-success">+ Saisir paiement</a>
                    {% else %}
                        <a href="{{ path('app_payment_new', {'quittance': r.id}) }}" class="btn-sm" style="opacity:.6">+ Paiement</a>
                    {% endif %}
                </div>
            </td>
        </tr>
    {% else %}
        <tr><td colspan="6" style="text-align:center;color:var(--text-muted);padding:2rem">Aucune quittance trouvée.</td></tr>
    {% endfor %}
    </tbody>
</table>
</div>
{% endblock %}
