{% extends 'base.html.twig' %}
{% block card_open %}{% endblock %}
{% block card_close %}{% endblock %}
{% block title %}Quittance {{ rent_receipt.number }}{% endblock %}
{% block body %}
    <div class="dashboard-header">
        <div>
            <h1>Quittance {{ rent_receipt.number }}</h1>
            <p class="dashboard-sub">{{ rent_receipt.tenant ? rent_receipt.tenant.name : '—' }}</p>
        </div>
        <div class="page-actions">
            <a href="{{ path('app_rent_receipt_index') }}" class="btn-sm">← Retour</a>
            {% if not rent_receipt.isPaid %}
                <a href="{{ path('app_payment_new', {'quittance': rent_receipt.id}) }}" class="btn-sm btn-success">+ Saisir paiement</a>
            {% endif %}
            <a href="{{ path('app_rent_receipt_edit', {'id': rent_receipt.id}) }}" class="btn">Modifier</a>
            {{ include('rent_receipt/_delete_form.html.twig') }}
        </div>
    </div>
    <div class="card">
    <dl class="detail-grid">
        <div class="detail-row"><dt>Numéro</dt><dd><span class="badge">{{ rent_receipt.number }}</span></dd></div>
        <div class="detail-row"><dt>Locataire</dt><dd>{{ rent_receipt.tenant ? rent_receipt.tenant.name : '—' }}</dd></div>
        <div class="detail-row"><dt>Période</dt><dd>{{ rent_receipt.periodStart|date('d/m/Y') }} → {{ rent_receipt.periodEnd|date('d/m/Y') }}</dd></div>
        <div class="detail-row"><dt>Montant</dt><dd><strong>{{ rent_receipt.amount }} €</strong></dd></div>
        <div class="detail-row"><dt>Émis le</dt><dd>{{ rent_receipt.issuedAt|date('d/m/Y') }}</dd></div>
        <div class="detail-row"><dt>Statut</dt><dd>
            {% if rent_receipt.isPaid %}
                <span style="padding:3px 10px;background:#dcfce7;color:#166534;border-radius:20px;font-size:.8rem;font-weight:600">✓ Payé</span>
            {% else %}
                <span style="padding:3px 10px;background:#fef9c3;color:#854d0e;border-radius:20px;font-size:.8rem;font-weight:600">⏳ En attente de paiement</span>
            {% endif %}
        </dd></div>
    </dl>
    </div>
{% endblock %}