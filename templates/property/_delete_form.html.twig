<form method="post" action="{{ path('app_property_delete', {'id': property.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce bien ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ property.id) }}">
    <button class="btn-danger">🗑 Supprimer</button>
</form>