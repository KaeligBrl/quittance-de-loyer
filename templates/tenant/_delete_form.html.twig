<form method="post" action="{{ path('app_tenant_delete', {'id': tenant.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce locataire ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tenant.id) }}">
    <button class="btn-danger">🗑 Supprimer</button>
</form>