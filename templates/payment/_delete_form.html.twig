<form method="post" action="{{ path('app_payment_delete', {'id': payment.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce paiement ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ payment.id) }}">
    <button class="btn-danger">🗑 Supprimer</button>
</form>