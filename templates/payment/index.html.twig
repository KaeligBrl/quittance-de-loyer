{% extends 'base.html.twig' %}
{% block card_open %}{% endblock %}
{% block card_close %}{% endblock %}
{% block title %}Liste des paiements{% endblock %}
{% block body %}
    <div class="dashboard-header">
        <div>
            <h1>Paiements</h1>
            <p class="dashboard-sub">Suivi des paiements reçus</p>
        </div>
        <a href="{{ path('app_payment_new') }}" class="btn">+ Nouveau paiement</a>
    </div>
    <div class="card">
    <table class="table">
        {% set methods = {'virement':'Virement bancaire','cheque':'Chèque','especes':'Espèces','prelevement':'Prélèvement automatique','autre':'Autre'} %}
        <thead>
            <tr>
                <th>Quittance</th>
                <th>Locataire</th>
                <th>Montant</th>
                <th>Payé le</th>
                <th>Méthode</th>
                <th>Note</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for payment in payments %}
            <tr>
                <td>
                    {% if payment.rentReceipt %}
                        <a href="{{ path('app_rent_receipt_show', {'id': payment.rentReceipt.id}) }}">
                            <span class="badge">{{ payment.rentReceipt.number }}</span>
                        </a>
                    {% else %}—{% endif %}
                </td>
                <td>{{ payment.rentReceipt ? payment.rentReceipt.tenantDisplayName : '—' }}</td>
                <td><strong>{{ payment.amount }} €</strong></td>
                <td>{{ payment.paidAt ? payment.paidAt|date('d/m/Y') : '—' }}</td>
                <td>{{ methods[payment.method] ?? payment.method ?? '—' }}</td>
                <td>{{ payment.note ?: '—' }}</td>
                <td>
                    <a href="{{ path('app_payment_show', {'id': payment.id}) }}" class="btn-sm">Voir</a>
                    <a href="{{ path('app_payment_edit', {'id': payment.id}) }}" class="btn-sm">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="7">Aucun paiement trouvé.</td></tr>
        {% endfor %}
        </tbody>
    </table>
    </div>
{% endblock %}